PORT=3001

# Local development (MongoDB installed on your PC):
MONGODB_URI=mongodb://localhost:27017/clinic-queue

# Production / Atlas (uncomment and replace USER, PASSWORD, cluster host):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/clinic-queue?retryWrites=true&w=majority&appName=Cluster0

# Comma-separated frontend URLs (no trailing slash). Local + deployed:
CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app
