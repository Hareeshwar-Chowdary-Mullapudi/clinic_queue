# ─── Local development ───────────────────────────────────────────────
# Copy this file to .env (optional for local dev).
#
# npm run dev uses the Vite proxy — socket connects via http://localhost:5173
# to backend on http://localhost:3001. You do NOT need VITE_SOCKET_URL locally.
#
# 1. cd backend && npm run dev
# 2. cd my-react-app && npm run dev
# 3. Open http://localhost:5173/receptionist

# ─── Production (Vercel) ─────────────────────────────────────────────
# Set in Vercel → Settings → Environment Variables, or use .env.production:
#
# VITE_SOCKET_URL=https://clinic-queue-2hso.onrender.com
